# Local-dev database URL. Points at the Supabase CLI local stack.
# Run `supabase start` once; copy the printed "DB URL" line to .env.local.
# Production / staging URLs: Doppler is the canonical source per SCAFFOLD.13-B; Vercel auto-synced via integration; local dev reads `.env.local` (Path A locked).
# Doppler service-token rotation (Vercel integration auth): https://docs.doppler.com/docs/service-tokens
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# === SCAFFOLD.14: Auth vendor credentials ===

# Google OAuth (Vendor 1 — F-AUTH-1 per SPEC.1 §13)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend (Vendor 2 — F-AUTH-2 OTP delivery per SPEC.1 §13 + ADR-0004 §5)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Cloudflare Turnstile (Vendor 3 — F-AUTH-2 CAPTCHA gate per SPEC.1 §13 + ADR-0004 §4)
# Get from: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Better Auth (local — session cookie signing + callback base URL per ADR-0004)
# Generate secret with: openssl rand -hex 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Admin auth (local — static password per ADR-0010)
# Generate with: openssl rand -hex 32
ADMIN_PASSWORD=

# === SCAFFOLD.4: Upstash Redis (rate-limit + idempotency) ===

# Upstash Redis (Vendor 4 — rate-limit middleware + idempotency cache per ADR-0006 §3 + ADR-0015)
# Get from: https://console.upstash.com/redis (create DB in ap-south-1 / Mumbai)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === SCAFFOLD.15: Cloudflare R2 (object storage) ===
#
# Two buckets, each with its own bucket-scoped API token per ADR-0006 §4 + B2 ratification.
# `zugzwang-uploads` is the dynamic (signed-PUT) bucket; `zugzwang-pfp` is the static
# (pre-baked PFPs) bucket per §12.1. R2 jurisdiction APAC (location hint `apac`).
#
# R2_ACCOUNT_ID is the Cloudflare account id (visible in dashboard URL).
# R2_ENDPOINT_* is the bucket-scoped S3-compat endpoint:
#   https://<account_id>.r2.cloudflarestorage.com
# (R2 routes by bucket via Host header; the same endpoint serves both buckets,
# but the per-bucket env vars keep the credential split explicit per B2.)
#
# R2_PUBLIC_URL_PFP is the public read URL base for PFPs. Experiment-phase
# uses the R2 public dev URL (`https://pub-<hash>.r2.dev`) per SCAFFOLD.15
# SURPRISE-8 — the originally-planned `cdn.zugzwangworld.com` custom-domain
# bind is deferred to post-experiment (Namecheap DNS / Cloudflare Business
# cost). Frontend composes `${R2_PUBLIC_URL_PFP}/v1/${pseudonym}.webp` per
# SPEC.2 §12.7.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID_UPLOADS=
R2_SECRET_ACCESS_KEY_UPLOADS=
R2_ENDPOINT_UPLOADS=
R2_ACCESS_KEY_ID_PFP=
R2_SECRET_ACCESS_KEY_PFP=
R2_ENDPOINT_PFP=
R2_PUBLIC_URL_PFP=

# === SCAFFOLD.15: OpenAI moderation (pre-commit moderation pipeline) ===
#
# Vendor 5 — pre-commit moderation per ADR-0014 + SPEC.2 §10. The `omni-moderation-2024-09-26`
# snapshot is pinned at `src/server/config/limits.ts` `OPENAI_MODERATION_MODEL_SNAPSHOT`.
# Get from: https://platform.openai.com/api-keys (scope: moderation-only)
OPENAI_API_KEY=

# === SCAFFOLD.15: Vercel Cron auth ===
#
# Bearer secret for `GET /api/cron/r2-orphan-sweep` per SPEC.2 §3.3 + §12.6. Vercel
# Cron supplies `Authorization: Bearer ${CRON_SECRET}` automatically when the env
# var is set on the Vercel project. Generate with: openssl rand -hex 32
CRON_SECRET=

# === SCAFFOLD.15: Live R2 probe gating (local dev only; never in prd) ===
#
# Default off. When `R2_PROBE_LIVE=true`, `tests/server/storage/_probe-r2-roundtrip.test.ts`
# runs against the real bucket using the `probe/` key prefix (NOT `u/` — keeps the
# operator lifecycle rule scoped to user uploads). Tests clean up after themselves.
# Leave unset for routine `pnpm vitest run`.
R2_PROBE_LIVE=
